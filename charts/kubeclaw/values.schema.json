{
  "$schema": "https://json-schema.org/draft-07/schema#",
  "title": "OpenClaw Helm Chart Values",
  "type": "object",
  "properties": {
    "replicaCount": {
      "type": "integer",
      "const": 1,
      "description": "Must always be 1. The OpenClaw Gateway is a stateful singleton that owns an exclusive WebSocket listener and all session/channel state. Multiple replicas cause port-collision failures and data corruption."
    },
    "image": {
      "type": "object",
      "required": ["repository", "tag", "digest"],
      "properties": {
        "repository": {
          "type": "string",
          "minLength": 1,
          "description": "Docker image repository for the OpenClaw Gateway."
        },
        "tag": {
          "type": "string",
          "minLength": 1,
          "description": "Docker image tag tested for this chart release."
        },
        "digest": {
          "type": "string",
          "minLength": 1,
          "pattern": "^sha256:[a-f0-9]{64}$",
          "description": "Immutable Docker image digest to prevent tag drift."
        },
        "pullPolicy": {
          "type": "string",
          "enum": ["Always", "IfNotPresent", "Never"]
        }
      }
    },
    "secret": {
      "type": "object",
      "properties": {
        "create": {
          "type": "boolean"
        },
        "existingSecretName": {
          "type": "string"
        },
        "data": {
          "type": "object",
          "additionalProperties": {
            "type": "string"
          }
        }
      }
    },
    "persistence": {
      "type": "object",
      "properties": {
        "storageClass": {
          "type": "string"
        },
        "size": {
          "type": "string",
          "pattern": "^[0-9]+(Ki|Mi|Gi|Ti|Pi|Ei|m|k|M|G|T|P|E)?$"
        },
        "splitVolumes": {
          "type": "boolean"
        },
        "fixPermissions": {
          "type": "object",
          "properties": {
            "enabled": { "type": "boolean" }
          }
        }
      }
    },
    "config": {
      "type": "object",
      "properties": {
        "desired": {
          "type": "string"
        },
        "mode": {
          "type": "string",
          "enum": ["merge", "overwrite"]
        }
      }
    },
    "tools": {
      "type": "object",
      "properties": {
        "enabled": { "type": "boolean" },
        "init": {
          "type": "object",
          "properties": {
            "enabled": { "type": "boolean" },
            "binDir": {
              "type": "string",
              "minLength": 1,
              "pattern": "^/tools(/.*)?$"
            },
            "resources": { "type": "object" }
          }
        },
        "clis": {
          "type": "object",
          "properties": {
            "github": {
              "type": "object",
              "properties": {
                "enabled": { "type": "boolean" },
                "version": {
                  "type": "string",
                  "minLength": 1
                },
                "downloadUrlTemplate": {
                  "type": "string",
                  "minLength": 1
                }
              }
            },
            "jira": {
              "type": "object",
              "properties": {
                "enabled": { "type": "boolean" },
                "version": {
                  "type": "string",
                  "minLength": 1
                },
                "downloadUrlTemplate": {
                  "type": "string",
                  "minLength": 1
                }
              }
            },
            "linear": {
              "type": "object",
              "properties": {
                "enabled": { "type": "boolean" },
                "version": {
                  "type": "string",
                  "minLength": 1
                },
                "downloadUrlTemplate": {
                  "type": "string",
                  "minLength": 1
                }
              }
            },
            "asana": {
              "type": "object",
              "properties": {
                "enabled": { "type": "boolean" },
                "version": {
                  "type": "string",
                  "minLength": 1
                },
                "downloadUrlTemplate": {
                  "type": "string",
                  "minLength": 1
                }
              }
            },
            "trello": {
              "type": "object",
              "properties": {
                "enabled": { "type": "boolean" },
                "version": {
                  "type": "string",
                  "minLength": 1
                }
              }
            }
          }
        }
      }
    },
    "github": {
      "type": "object",
      "properties": {
        "enabled": { "type": "boolean" },
        "auth": {
          "type": "object",
          "properties": {
            "token": { "type": "string" }
          }
        }
      }
    },
    "jira": {
      "type": "object",
      "properties": {
        "enabled": { "type": "boolean" },
        "auth": {
          "type": "object",
          "properties": {
            "token": { "type": "string" }
          }
        }
      }
    },
    "linear": {
      "type": "object",
      "properties": {
        "enabled": { "type": "boolean" },
        "auth": {
          "type": "object",
          "properties": {
            "token": { "type": "string" }
          }
        }
      }
    },
    "asana": {
      "type": "object",
      "properties": {
        "enabled": { "type": "boolean" },
        "auth": {
          "type": "object",
          "properties": {
            "token": { "type": "string" }
          }
        }
      }
    },
    "trello": {
      "type": "object",
      "properties": {
        "enabled": { "type": "boolean" },
        "auth": {
          "type": "object",
          "properties": {
            "apiKey": { "type": "string" },
            "token": { "type": "string" }
          }
        }
      }
    },
    "gatewayAPI": {
      "type": "object",
      "properties": {
        "enabled": { "type": "boolean" },
        "gatewayClassName": { "type": "string" },
        "host": { "type": "string" },
        "routes": { "type": "object" },
        "tls": { "type": "object" },
        "annotations": { "type": "object" },
        "crds": {
          "type": "object",
          "properties": {
            "install": { "type": "boolean" }
          }
        },
        "controller": {
          "type": "object",
          "properties": {
            "enabled": { "type": "boolean" },
            "gatewayClassName": { "type": "string" }
          }
        }
      }
    },
    "envoy-gateway": {
      "type": "object"
    },
    "ingress": {
      "type": "object",
      "properties": {
        "enabled": {
          "type": "boolean"
        },
        "host": {
          "type": "string"
        }
      }
    },
    "networkPolicy": {
      "type": "object",
      "properties": {
        "enabled": {
          "type": "boolean"
        }
      }
    },
    "chromium": {
      "type": "object",
      "properties": {
        "enabled": {
          "type": "boolean"
        }
      }
    },
    "egressFilter": {
      "type": "object",
      "properties": {
        "enabled": {
          "type": "boolean"
        },
        "replicas": {
          "type": "integer",
          "minimum": 1
        },
        "blockCountries": {
          "type": "array",
          "items": {
            "type": "string",
            "pattern": "^[A-Z]{2}$"
          }
        },
        "denylists": {
          "type": "object",
          "additionalProperties": {
            "type": "array",
            "items": { "type": "string" }
          }
        },
        "allowlists": {
          "type": "array",
          "items": { "type": "string" }
        },
        "customConfig": {
          "type": "string"
        }
      }
    },
    "backup": {
      "type": "object",
      "properties": {
        "enabled": { "type": "boolean" },
        "image": {
          "type": "object",
          "properties": {
            "repository": { "type": "string" },
            "tag": { "type": "string" },
            "pullPolicy": {
              "type": "string",
              "enum": ["Always", "IfNotPresent", "Never"]
            }
          }
        },
        "schedule": { "type": "string" },
        "pathPrefix": { "type": "string" },
        "concurrencyPolicy": {
          "type": "string",
          "enum": ["Allow", "Forbid", "Replace"]
        },
        "successfulJobsHistoryLimit": {
          "type": "integer",
          "minimum": 0
        },
        "failedJobsHistoryLimit": {
          "type": "integer",
          "minimum": 0
        },
        "onDelete": {
          "type": "object",
          "properties": {
            "enabled": { "type": "boolean" }
          }
        },
        "resources": { "type": "object" }
      }
    },
    "diagnostics": {
      "type": "object",
      "properties": {
        "enabled": {
          "type": "boolean"
        },
        "schedule": {
          "type": "string"
        },
        "nodeOptions": {
          "type": "string"
        }
      }
    },
    "service": {
      "type": "object",
      "properties": {
        "type": {
          "type": "string",
          "enum": ["ClusterIP", "NodePort", "LoadBalancer"]
        },
        "port": {
          "type": "integer"
        }
      }
    },
    "tailscale": {
      "type": "object",
      "properties": {
        "expose": {
          "type": "object",
          "properties": {
            "enabled": { "type": "boolean" },
            "hostname": { "type": "string" },
            "tags": { "type": "string" }
          }
        },
        "ssh": {
          "type": "object",
          "properties": {
            "enabled": { "type": "boolean" },
            "image": { "type": "object" },
            "authKey": { "type": "string" },
            "authKeySecretName": { "type": "string" },
            "authKeySecretKey": { "type": "string" },
            "hostname": { "type": "string" },
            "userspace": { "type": "boolean" },
            "persistState": { "type": "boolean" },
            "stateStorage": { "type": "object" },
            "extraEnv": { "type": "array" },
            "resources": { "type": "object" }
          }
        }
      }
    },
    "observability": {
      "type": "object",
      "properties": {
        "enabled": {
          "type": "boolean"
        },
        "gateway": {
          "type": "object",
          "properties": {
            "enabled": { "type": "boolean" },
            "serviceName": { "type": "string" },
            "resourceAttributes": { "type": "string" }
          }
        },
        "nodeCollector": {
          "type": "object",
          "properties": {
            "enabled": { "type": "boolean" },
            "image": { "type": "object" },
            "resources": { "type": "object" },
            "tolerations": { "type": "array" }
          }
        },
        "clusterCollector": {
          "type": "object",
          "properties": {
            "enabled": { "type": "boolean" },
            "image": { "type": "object" },
            "resources": { "type": "object" }
          }
        },
        "ingress": {
          "type": "object",
          "properties": {
            "enabled": { "type": "boolean" },
            "className": { "type": "string" },
            "host": { "type": "string" },
            "tls": { "type": "array" }
          }
        }
      }
    },
    "clickstack": {
      "type": "object"
    },
    "skillStacks": {
      "type": "object",
      "properties": {
        "enabled": { "type": "boolean" },
        "nodeManager": {
          "type": "string",
          "enum": ["npm", "yarn", "pnpm"]
        },
        "watch": { "type": "boolean" },
        "extraDirs": {
          "type": "array",
          "items": { "type": "string" }
        },
        "platformEngineering": {
          "type": "object",
          "properties": { "enabled": { "type": "boolean" } }
        },
        "devops": {
          "type": "object",
          "properties": { "enabled": { "type": "boolean" } }
        },
        "sre": {
          "type": "object",
          "properties": { "enabled": { "type": "boolean" } }
        },
        "swe": {
          "type": "object",
          "properties": { "enabled": { "type": "boolean" } }
        },
        "qa": {
          "type": "object",
          "properties": { "enabled": { "type": "boolean" } }
        },
        "marketing": {
          "type": "object",
          "properties": { "enabled": { "type": "boolean" } }
        },
        "initResources": { "type": "object" }
      }
    },
    "obsidian": {
      "type": "object",
      "properties": {
        "enabled": { "type": "boolean" },
        "mountPath": {
          "type": "string",
          "minLength": 1
        },
        "persistence": {
          "type": "object",
          "properties": {
            "storageClass": { "type": "string" },
            "size": {
              "type": "string",
              "pattern": "^[0-9]+(Ki|Mi|Gi|Ti|Pi|Ei|m|k|M|G|T|P|E)?$"
            },
            "accessModes": {
              "type": "array",
              "items": {
                "type": "string",
                "enum": ["ReadWriteOnce", "ReadOnlyMany", "ReadWriteMany"]
              }
            }
          }
        }
      }
    },
    "memory": {
      "type": "object",
      "properties": {
        "enabled": { "type": "boolean" },
        "image": {
          "type": "object",
          "properties": {
            "repository": { "type": "string" },
            "tag": { "type": "string" },
            "pullPolicy": {
              "type": "string",
              "enum": ["Always", "IfNotPresent", "Never"]
            }
          }
        },
        "qmd": {
          "type": "object",
          "properties": {
            "packageUrl": {
              "type": "string",
              "minLength": 1
            }
          }
        },
        "initResources": { "type": "object" },
        "update": {
          "type": "object",
          "properties": {
            "schedule": { "type": "string" },
            "concurrencyPolicy": {
              "type": "string",
              "enum": ["Allow", "Forbid", "Replace"]
            },
            "successfulJobsHistoryLimit": { "type": "integer", "minimum": 0 },
            "failedJobsHistoryLimit": { "type": "integer", "minimum": 0 },
            "resources": { "type": "object" }
          }
        },
        "embed": {
          "type": "object",
          "properties": {
            "schedule": { "type": "string" },
            "concurrencyPolicy": {
              "type": "string",
              "enum": ["Allow", "Forbid", "Replace"]
            },
            "successfulJobsHistoryLimit": { "type": "integer", "minimum": 0 },
            "failedJobsHistoryLimit": { "type": "integer", "minimum": 0 },
            "resources": { "type": "object" }
          }
        }
      }
    },
    "litellm": {
      "type": "object",
      "properties": {
        "enabled": {
          "type": "boolean"
        },
        "masterkey": {
          "type": "string"
        },
        "environmentSecrets": {
          "type": "array",
          "items": { "type": "string" }
        },
        "proxy_config": {
          "type": "object"
        },
        "db": {
          "type": "object",
          "properties": {
            "deployStandalone": { "type": "boolean" }
          }
        },
        "redis": {
          "type": "object",
          "properties": {
            "enabled": { "type": "boolean" }
          }
        },
        "replicaCount": {
          "type": "integer"
        }
      }
    }
  },
  "if": {
    "properties": {
      "replicaCount": {
        "not": {
          "const": 1
        }
      }
    },
    "required": ["replicaCount"]
  },
  "then": {
    "properties": {
      "replicaCount": {
        "const": 1,
        "description": "ERROR: replicaCount must be 1. The OpenClaw Gateway does not support horizontal scaling."
      }
    }
  }
}
