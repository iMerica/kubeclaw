{
  "$schema": "https://json-schema.org/draft-07/schema#",
  "title": "OpenClaw Helm Chart Values",
  "type": "object",
  "properties": {
    "replicaCount": {
      "type": "integer",
      "const": 1,
      "description": "Must always be 1. The OpenClaw Gateway is a stateful singleton that owns an exclusive WebSocket listener and all session/channel state. Multiple replicas cause port-collision failures and data corruption."
    },
    "image": {
      "type": "object",
      "required": ["repository", "tag", "digest"],
      "properties": {
        "repository": {
          "type": "string",
          "minLength": 1,
          "description": "Docker image repository for the OpenClaw Gateway."
        },
        "tag": {
          "type": "string",
          "minLength": 1,
          "description": "Docker image tag tested for this chart release."
        },
        "digest": {
          "type": "string",
          "minLength": 1,
          "pattern": "^sha256:[a-f0-9]{64}$",
          "description": "Immutable Docker image digest to prevent tag drift."
        },
        "pullPolicy": {
          "type": "string",
          "enum": ["Always", "IfNotPresent", "Never"]
        }
      }
    },
    "secret": {
      "type": "object",
      "properties": {
        "create": {
          "type": "boolean"
        },
        "existingSecretName": {
          "type": "string"
        },
        "data": {
          "type": "object",
          "additionalProperties": {
            "type": "string"
          }
        }
      }
    },
    "persistence": {
      "type": "object",
      "properties": {
        "storageClass": {
          "type": "string"
        },
        "size": {
          "type": "string",
          "pattern": "^[0-9]+(Ki|Mi|Gi|Ti|Pi|Ei|m|k|M|G|T|P|E)?$"
        },
        "splitVolumes": {
          "type": "boolean"
        }
      }
    },
    "config": {
      "type": "object",
      "properties": {
        "desired": {
          "type": "string"
        },
        "mode": {
          "type": "string",
          "enum": ["merge", "overwrite"]
        }
      }
    },
    "ingress": {
      "type": "object",
      "properties": {
        "enabled": {
          "type": "boolean"
        },
        "host": {
          "type": "string"
        }
      }
    },
    "networkPolicy": {
      "type": "object",
      "properties": {
        "enabled": {
          "type": "boolean"
        }
      }
    },
    "chromium": {
      "type": "object",
      "properties": {
        "enabled": {
          "type": "boolean"
        }
      }
    },
    "diagnostics": {
      "type": "object",
      "properties": {
        "enabled": {
          "type": "boolean"
        },
        "schedule": {
          "type": "string"
        }
      }
    },
    "service": {
      "type": "object",
      "properties": {
        "type": {
          "type": "string",
          "enum": ["ClusterIP", "NodePort", "LoadBalancer"]
        },
        "port": {
          "type": "integer"
        }
      }
    },
    "tailscale": {
      "type": "object",
      "properties": {
        "expose": {
          "type": "object",
          "properties": {
            "enabled": { "type": "boolean" },
            "hostname": { "type": "string" },
            "tags": { "type": "string" }
          }
        },
        "ssh": {
          "type": "object",
          "properties": {
            "enabled": { "type": "boolean" },
            "image": { "type": "object" },
            "authKey": { "type": "string" },
            "authKeySecretName": { "type": "string" },
            "authKeySecretKey": { "type": "string" },
            "hostname": { "type": "string" },
            "userspace": { "type": "boolean" },
            "persistState": { "type": "boolean" },
            "stateStorage": { "type": "object" },
            "extraEnv": { "type": "array" },
            "resources": { "type": "object" }
          }
        }
      }
    },
    "litellm": {
      "type": "object",
      "properties": {
        "enabled": {
          "type": "boolean"
        },
        "masterkey": {
          "type": "string"
        },
        "masterkeySecretName": {
          "type": "string"
        },
        "masterkeySecretKey": {
          "type": "string"
        },
        "environmentSecrets": {
          "type": "array",
          "items": { "type": "string" }
        },
        "proxy_config": {
          "type": "object"
        },
        "db": {
          "type": "object",
          "properties": {
            "deployStandalone": { "type": "boolean" }
          }
        },
        "redis": {
          "type": "object",
          "properties": {
            "enabled": { "type": "boolean" }
          }
        },
        "replicaCount": {
          "type": "integer"
        }
      }
    }
  },
  "allOf": [
    {
      "if": {
        "properties": {
          "tailscale": {
            "properties": {
              "ssh": {
                "properties": {
                  "enabled": { "const": true }
                },
                "required": ["enabled"]
              }
            },
            "required": ["ssh"]
          }
        },
        "required": ["tailscale"]
      },
      "then": {
        "properties": {
          "tailscale": {
            "properties": {
              "ssh": {
                "anyOf": [
                  {
                    "properties": {
                      "authKey": {
                        "type": "string",
                        "minLength": 4
                      }
                    },
                    "required": ["authKey"]
                  },
                  {
                    "properties": {
                      "authKeySecretName": {
                        "type": "string",
                        "minLength": 1
                      }
                    },
                    "required": ["authKeySecretName"]
                  }
                ]
              }
            }
          }
        }
      }
    },
    {
      "if": {
        "properties": {
          "litellm": {
            "properties": {
              "enabled": { "const": true }
            },
            "required": ["enabled"]
          }
        },
        "required": ["litellm"]
      },
      "then": {
        "properties": {
          "litellm": {
            "anyOf": [
              {
                "properties": {
                  "masterkey": {
                    "type": "string",
                    "pattern": "^sk-",
                    "minLength": 4
                  }
                },
                "required": ["masterkey"]
              },
              {
                "properties": {
                  "masterkeySecretName": {
                    "type": "string",
                    "minLength": 1
                  }
                },
                "required": ["masterkeySecretName"]
              }
            ]
          }
        }
      }
    }
  ],
  "if": {
    "properties": {
      "replicaCount": {
        "not": {
          "const": 1
        }
      }
    },
    "required": ["replicaCount"]
  },
  "then": {
    "properties": {
      "replicaCount": {
        "const": 1,
        "description": "ERROR: replicaCount must be 1. The OpenClaw Gateway does not support horizontal scaling."
      }
    }
  }
}
