{
  "$schema": "https://json-schema.org/draft-07/schema#",
  "title": "OpenClaw Helm Chart Values",
  "type": "object",
  "properties": {
    "replicaCount": {
      "type": "integer",
      "const": 1,
      "description": "Must always be 1. The OpenClaw Gateway is a stateful singleton that owns an exclusive WebSocket listener and all session/channel state. Multiple replicas cause port-collision failures and data corruption."
    },
    "image": {
      "type": "object",
      "required": ["repository", "tag"],
      "properties": {
        "repository": {
          "type": "string",
          "minLength": 1,
          "description": "Docker image repository for the OpenClaw Gateway."
        },
        "tag": {
          "type": "string",
          "minLength": 1,
          "description": "Docker image tag. Pin to a specific release in production."
        },
        "pullPolicy": {
          "type": "string",
          "enum": ["Always", "IfNotPresent", "Never"]
        }
      }
    },
    "secret": {
      "type": "object",
      "properties": {
        "create": {
          "type": "boolean"
        },
        "existingSecretName": {
          "type": "string"
        },
        "data": {
          "type": "object",
          "additionalProperties": {
            "type": "string"
          }
        }
      }
    },
    "persistence": {
      "type": "object",
      "properties": {
        "storageClass": {
          "type": "string"
        },
        "size": {
          "type": "string",
          "pattern": "^[0-9]+(Ki|Mi|Gi|Ti|Pi|Ei|m|k|M|G|T|P|E)?$"
        },
        "splitVolumes": {
          "type": "boolean"
        }
      }
    },
    "config": {
      "type": "object",
      "properties": {
        "desired": {
          "type": "string"
        },
        "mode": {
          "type": "string",
          "enum": ["merge", "overwrite"]
        }
      }
    },
    "ingress": {
      "type": "object",
      "properties": {
        "enabled": {
          "type": "boolean"
        },
        "host": {
          "type": "string"
        }
      }
    },
    "networkPolicy": {
      "type": "object",
      "properties": {
        "enabled": {
          "type": "boolean"
        }
      }
    },
    "chromium": {
      "type": "object",
      "properties": {
        "enabled": {
          "type": "boolean"
        }
      }
    },
    "diagnostics": {
      "type": "object",
      "properties": {
        "enabled": {
          "type": "boolean"
        },
        "schedule": {
          "type": "string"
        }
      }
    },
    "service": {
      "type": "object",
      "properties": {
        "type": {
          "type": "string",
          "enum": ["ClusterIP", "NodePort", "LoadBalancer"]
        },
        "port": {
          "type": "integer"
        }
      }
    }
  },
  "if": {
    "properties": {
      "replicaCount": {
        "not": {
          "const": 1
        }
      }
    },
    "required": ["replicaCount"]
  },
  "then": {
    "properties": {
      "replicaCount": {
        "const": 1,
        "description": "ERROR: replicaCount must be 1. The OpenClaw Gateway does not support horizontal scaling."
      }
    }
  }
}
